pipeline{
    agent any

    parameters{
        booleanParam: 'DEPLOY', description: 'want to deploy to production'
    }


    environment {
        CURRENT_ENV = 'prod'
    }

    stages{
        stage('STAGE1') {
            when{
                branch 'main'
            }
            steps{
                echo "This is stage 1"
                sh '''
                    sleep 5
                    echo "this is stage1"
                    exit 1
                    '''
                 }
            }
        
        stage('when enviroment') {
            when{
                environment name: 'CURRENT_ENV', value:'prod'
            }
            steps{
                echo "This is FINAL stage "
                sh '''
                    sleep 5
                    echo "this is FINAL stage"
                    '''
                }
            }

        stage('when parameter') {
            when{
                expression{params.DEPLOY==true }
            }
            steps{
                echo "This is FINAL stage "
                sh '''
                    sleep 5
                    echo "this is FINAL stage"
                    '''
                }
            }
        }
    }