pipeline{
    agent any

    stages{
        stage('STAGE1_a') {
            steps{
                catchError(buildResult: 'SUCCESS',stageResult: 'FAILURE'){
                echo "This is stage 1"
                sh '''
                    sleep 5
                    echo "this is stage1"
                    exit 1
                    '''
                    }
                 }
            }
         stage('STAGE1_b') {
            steps{
                script{
                    try{
                        sh '''
                            sleep 5
                            exit 1
                             '''
                    }
                    catch (err) {
                        echo "Error caught: $(err)"
                        currentBuild.result ='SUCCESS'
                        currentstage.result = 'FAILURE'
                    }
               
                        }
                    }
                 }
            }    
        stage('PARALLEL TESTING') {
             parallel{
                stage('WINDOWS TESTING') { 
                    steps {
                        echo "this is WINDOWS"
                        sh '''#!/bin/bash
                         sleep 10
                         '''
                
                    }            
                }
           
                stage('MAC TESTING') { 
                    steps {
                    echo "this is MAC"
                    sh '''#!/bin/bash
                      sleep 10
                      '''
                    }
                 
                }
                stage('LINUX TESTING') { 
                    steps {
                    echo "this is LINUX"
                    sh '''#!/bin/bash
                      sleep 10   
                      '''            
                    }
               
                }

            }
        }

        stage('FINAL') {
            steps{
                echo "This is FINAL stage "
                sh '''
                    sleep 5
                    echo "this is FINAL stage"
                    '''
                }
            }
        }
    }